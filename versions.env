# Pinned versions for reproducible deployment. Update deliberately, not "latest".
# Verify each on the device before bumping.
#
# SCOPE: the Jetson is a GPU INFERENCE NODE only. It runs llama.cpp (LLM) and
# whisper.cpp (STT) NATIVELY (no Docker). TTS (Piper) and the OpenClaw agent
# harness run on a SEPARATE mini-PC and are NOT pinned here.

# Platform
JETPACK_VERSION=7.2
L4T_VERSION=r39.2
CUDA_VERSION=13.2
GPU_ARCH=87            # Orin compute capability 8.7 (sm_87)

# Boot media: NVIDIA "Jetson ISO" installer (write to a >=16GB USB stick).
# Installs Jetson Linux directly onto the NVMe; the firmware capsule is baked in.
JETSON_ISO=jetsoninstaller-r39.2.0-2026-06-01-23-53-13-arm64.iso
JETSON_ISO_SHA256=6B51D397543C45A9AA46E7A1BEBE06F5513F5E0C969C2BF71DA2361B60EB593F

# CUDA build toolchain (apt; matches the host driver/runtime, CUDA 13.2)
CUDA_BUILD_PKGS="cuda-minimal-build-13-2 cuda-nvrtc-dev-13-2 libcublas-dev-13-2 cmake g++ libcurl4-openssl-dev ccache"

# LLM engine + model (native build)
LLAMACPP_REPO=https://github.com/ggml-org/llama.cpp.git
LLAMACPP_COMMIT=9c0ac88        # pin a verified commit; bump deliberately
LLM_MODEL=Qwen3-8B-Q4_K_M.gguf
LLM_PORT=8080

# STT engine + model (native build)
WHISPERCPP_REPO=https://github.com/ggml-org/whisper.cpp.git
WHISPERCPP_COMMIT=43d78af      # pin a verified commit; bump deliberately
STT_MODEL=ggml-large-v3-turbo-q5_0.bin
STT_PORT=8081

# Off-Jetson (mini-PC) - documented for context only, not installed on the Jetson
# TTS_ENGINE=piper
# AGENT_HARNESS=openclaw        # pin once chosen, on the mini-PC
