# Pinned versions for reproducible deployment. Update deliberately, not "latest".
# Verify each on the device before bumping.

# Platform
JETPACK_VERSION=6.2
L4T_VERSION=r36.4

# Inference (jetson-containers / dustynv images — confirm exact tags on device)
LLAMACPP_IMAGE=dustynv/llama_cpp:r36.4.0
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main

# Voice (Wyoming)
WYOMING_WHISPER_IMAGE=rhasspy/wyoming-whisper:latest
WYOMING_PIPER_IMAGE=rhasspy/wyoming-piper:latest

# Agent harness
OPENCLAW_VERSION=latest          # pin to a concrete version once chosen
NODE_MAJOR=24

# Models (confirm exact ids with `openclaw models list`)
MODEL_CLOUD_PRIMARY=github-copilot/claude-opus-4.8
MODEL_LOCAL_FALLBACK=llamacpp/gemma-3-4b
