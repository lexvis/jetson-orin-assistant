# Pinned versions for reproducible deployment. Update deliberately, not "latest".
# Verify each on the device before bumping.

# Platform
JETPACK_VERSION=7.2
L4T_VERSION=r39.2

# Boot media: NVIDIA "Jetson ISO" installer (write to a >=16GB USB stick).
# Installs Jetson Linux directly onto the NVMe; the firmware capsule is baked in.
JETSON_ISO=jetsoninstaller-r39.2.0-2026-06-01-23-53-13-arm64.iso
JETSON_ISO_SHA256=6B51D397543C45A9AA46E7A1BEBE06F5513F5E0C969C2BF71DA2361B60EB593F

# Inference (jetson-containers / dustynv images)
# IMPORTANT: the image tag must match your JetPack/L4T (CUDA) version. JetPack 7.2
# (r39.2) is new - confirm a current tag at github.com/dusty-nv/jetson-containers
# before pulling. The r36.x tags are JetPack 6 (CUDA 12) and will NOT run on JP7.
LLAMACPP_IMAGE=dustynv/llama_cpp:r39.2.0   # VERIFY this tag exists before pulling
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main

# Voice (Wyoming)
WYOMING_WHISPER_IMAGE=rhasspy/wyoming-whisper:latest
WYOMING_PIPER_IMAGE=rhasspy/wyoming-piper:latest

# Agent harness
OPENCLAW_VERSION=latest          # pin to a concrete version once chosen
NODE_MAJOR=24

# Models (confirm exact ids with `openclaw models list`)
MODEL_CLOUD_PRIMARY=github-copilot/claude-opus-4.8
MODEL_LOCAL_FALLBACK=llamacpp/gemma-3-4b
