# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).

# --- GitHub Copilot (optional cloud model offload) ---
# Token used for headless/cron OpenClaw runs against github-copilot/* models.
GITHUB_TOKEN=

# --- WhatsApp Cloud API (official) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- WireGuard (admin access; keys generated on-device, not stored here) ---
WG_SERVER_PUBLIC_ENDPOINT=vps.example.com:51820

# --- Open WebUI ---
OPENWEBUI_SECRET_KEY=
